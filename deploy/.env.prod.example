# =============================================================================
# NAC-Pay production environment — TEMPLATE
# Copy to `.env.prod` ON THE SERVER and fill in real values.
# The real .env.prod holds secrets and must NEVER be committed.
# =============================================================================

# --- Core ---------------------------------------------------------------
# Secret used to sign session cookies. Generate a fresh one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# Require login for all non-public routes. Always "true" in production.
AUTH_REQUIRED=true

# Public base URL. Used in verification/reset emails and Stripe redirects.
BASE_URL=https://pch-ledger.com

# --- Email (account verification + password reset) ----------------------
# "console" logs the links instead of sending (fine for the very first smoke
# test); "resend" sends real email via the Resend API.
EMAIL_BACKEND=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@pch-ledger.com

# --- Billing (Stripe) ---------------------------------------------------
# "fake" bypasses real charges (start here); "real" requires the keys below.
STRIPE_BACKEND=fake
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Schedule feed updater ----------------------------------------------
# Background task that hourly fetches each opted-in user's iCal feed URL
# (Settings → "Auto-update hourly") and applies it to the current + next
# month. Off unless set to true. The cadence is overridable in seconds.
FEED_UPDATER_ENABLED=true
# FEED_UPDATE_INTERVAL_SECONDS=3600

# --- Database -----------------------------------------------------------
# Default is SQLite under NAC_PAY_DATA_DIR (the /data volume) — leave unset.
# To move to Postgres later, set this and it takes precedence:
# NAC_PAY_DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/nac_pay
